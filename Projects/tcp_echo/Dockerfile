FROM alpine:3.20

# Устанавливаем ncat один раз на этапе сборки образа,
# чтобы при обычном запуске контейнера пакет не скачивался повторно.
RUN apk add --no-cache nmap-ncat

# Порт TCP-сервера, который слушает ncat.
EXPOSE 12345

# Простой TCP-сервер с keep-alive и выводом диагностик в stdout.
CMD ["ncat", "-vlk", "12345"]
