  },
  {
    "id": "fn_generate_meteo",
    "type": "function",
    "z": "tab_week12_meteo",
    "name": "Generate temperature & humidity",
    "func": "// Генерируем данные, совместимые с методичкой: отдельные топики для температуры и влажности.\nconst now = new Date().toISOString();\nconst temp = Number((19.5 + Math.random()).toFixed(2));\nconst hum = Number((58 + (5 * Math.random())).toFixed(2));\nreturn [\n  { topic: \"iot_practice/sim/temperature\", payload: temp, ts: now },\n  { topic: \"iot_practice/sim/humidity\", payload: hum, ts: now }\n];",
    "outputs": 2,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 470,
    "y": 180,
    "wires": [
      ["mqtt_out_temp", "fn_temp_to_influx", "debug_temp"],
      ["mqtt_out_hum", "fn_hum_to_influx", "debug_hum"]
    ]
  },
  {
