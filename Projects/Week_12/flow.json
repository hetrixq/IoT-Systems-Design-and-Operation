  {
    "id": "fn_temp_to_influx",
    "type": "function",
    "z": "tab_week12_meteo",
    "name": "Build Influx write (temperature)",
    "func": "// Формируем Line Protocol и заголовки для записи в InfluxDB 2.x API.\nmsg.method = \"POST\";\nmsg.url = \"http://influxdb:8086/api/v2/write?org=iot&bucket=meteo&precision=ms\";\nmsg.headers = {\n  \"Authorization\": \"Token __INFLUX_TOKEN__\",\n  \"Content-Type\": \"text/plain; charset=utf-8\"\n};\nmsg.payload = `temperature value=${Number(msg.payload)}`;\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 790,
    "y": 150,
    "wires": [["http_write_influx", "debug_write_temp"]]
  },
  {
    "id": "fn_hum_to_influx",
    "type": "function",
    "z": "tab_week12_meteo",
    "name": "Build Influx write (humidity)",
    "func": "// Формируем отдельную запись по влажности в тот же bucket.\nmsg.method = \"POST\";\nmsg.url = \"http://influxdb:8086/api/v2/write?org=iot&bucket=meteo&precision=ms\";\nmsg.headers = {\n  \"Authorization\": \"Token __INFLUX_TOKEN__\",\n  \"Content-Type\": \"text/plain; charset=utf-8\"\n};\nmsg.payload = `humidity value=${Number(msg.payload)}`;\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 780,
    "y": 290,
    "wires": [["http_write_influx", "debug_write_hum"]]
  },
