  {
    "id": "inject_meteo_30s",
    "type": "inject",
    "z": "tab_week12_meteo",
    "name": "Generate meteo every 30s",
    "props": [{ "p": "payload" }],
    "repeat": "30",
    "crontab": "",
    "once": true,
    "onceDelay": "2",
    "topic": "",
    "payload": "",
    "payloadType": "date",
    "x": 200,
    "y": 180,
