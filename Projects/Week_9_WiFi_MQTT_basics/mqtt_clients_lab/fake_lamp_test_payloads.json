{
  "base_topic": "iot_practice/USER_ID",
  "test_sequence": [
    {
      "topic": "iot_practice/USER_ID/lamp",
      "payload": "on",
      "expectation": "Lamp turns on in fake_lamp and GUI."
    },
    {
      "topic": "iot_practice/USER_ID/lamp/mode",
      "payload": "dimmer",
      "expectation": "Dimmer controls visible, RGB controls hidden."
    },
    {
      "topic": "iot_practice/USER_ID/lamp/value",
      "payload": "35",
      "expectation": "Brightness changes to 35%."
    },
    {
      "topic": "iot_practice/USER_ID/lamp/mode",
      "payload": "rgb",
      "expectation": "RGB controls visible, dimmer-only controls hidden."
    },
    {
      "topic": "iot_practice/USER_ID/lamp/color",
      "payload": "rgba(12,140,255,1.0)",
      "expectation": "Color updates to blue tone from RGBA payload."
    },
    {
      "topic": "iot_practice/USER_ID/lamp/color",
      "payload": "#FF6600",
      "expectation": "Color updates to orange tone from HEX payload."
    },
    {
      "topic": "iot_practice/USER_ID/lamp",
      "payload": "off",
      "expectation": "Lamp turns off in all connected clients."
    }
  ]
}
