  {
    "id": "fn_validate_eco",
    "type": "function",
    "z": "tab_eco_5404",
    "name": "validate + classify PM2.5",
    "func": "const data = msg.payload;\nif (!data || typeof data !== \"object\") {\n    return null;\n}\n\nconst toNum = (v) => {\n    const n = Number(v);\n    return Number.isFinite(n) ? n : null;\n};\n\nconst lat = toNum(data.lat);\nconst lon = toNum(data.lon);\nconst temperature = toNum(data.temperature);\nconst humidity = toNum(data.humidity);\nconst pm25 = toNum(data.pm25);\n\nif (lat === null || lon === null || temperature === null || humidity === null || pm25 === null) {\n    return null;\n}\n\nconst stationId = (typeof data.deviceId === \"string\" && data.deviceId.trim())\n    ? data.deviceId.trim()\n    : `Eco-${(msg.topic || \"\").split(\"/\")[1] || \"unknown\"}`;\n\nlet pmState = \"normal\";\nif (pm25 > 35) {\n    pmState = \"critical\";\n} else if (pm25 > 12) {\n    pmState = \"elevated\";\n}\n\nmsg.payload = {\n    ...data,\n    stationId,\n    pmState,\n    receivedAt: new Date().toISOString()\n};\n\nmsg.alert = (pmState === \"critical\");\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 610,
    "y": 140,
    "wires": [
      [
        "debug_valid_eco",
        "switch_alert_eco"
      ]
    ]
  },
