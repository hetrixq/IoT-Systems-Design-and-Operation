  {
    "id": "fn_build_alert",
    "type": "function",
    "z": "tab_eco_5404",
    "name": "build alert payload",
    "func": "const stationId = msg.payload.stationId || \"Eco-unknown\";\nconst pm25 = Number(msg.payload.pm25);\nmsg.topic = \"iot_practice/5404/eco/alert\";\nmsg.payload = {\n    stationId,\n    pm25,\n    level: \"critical\",\n    message: `Критическое загрязнение воздуха: ${pm25.toFixed(1)} мкг/м³`,\n    ts: new Date().toISOString()\n};\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
